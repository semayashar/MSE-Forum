{
  "version": "0.2.0",
  "configurations": [
    {
      "type": "java",
      "name": "ForumApplication (local)",
      "request": "launch",
      "mainClass": "com.mse.edu.forum.ForumApplication",
      "env": {
        "SPRING_PROFILES_ACTIVE": "local",
        "SERVER_PORT": "9000"
      }
    },
    {
      "type": "java",
      "name": "ForumApplication (docker postgres)",
      "request": "launch",
      "mainClass": "com.mse.edu.forum.ForumApplication",
      "env": {
        "SPRING_PROFILES_ACTIVE": "dev",
        "JWT_SECRET": "change-me-to-a-long-random-secret-at-least-32-chars",
        "JWT_EXPIRATION_MS": "86400000",
        "SPRING_DATASOURCE_URL": "jdbc:postgresql://localhost:5432/forum",
        "SPRING_DATASOURCE_USERNAME": "forum_app",
        "SPRING_DATASOURCE_PASSWORD": "forum_app_password",
        "SERVER_PORT": "9000"
      }
    }
  ]
}
