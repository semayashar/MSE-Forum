{
  "version": "0.2.0",
  "configurations": [
    {
      "type": "java",
      "name": "ForumApplication",
      "request": "launch",
      "mainClass": "com.mse.edu.forum.ForumApplication",
      "projectName": "forum",
      "env": {
        "SPRING_PROFILES_ACTIVE": "dev",
        "JWT_SECRET": "change-me-to-a-long-random-secret-at-least-32-chars",
